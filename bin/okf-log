#!/usr/bin/env python3
"""okf-log - generate an OKF log.md from git history (section 7).

Git is the episodic memory; log.md is just the OKF-conformant *view* of it.
Renders commits as date-grouped entries, newest first, with ISO 8601 date
headings (section 7). Each entry is a prose line with a bold leading word derived
from the conventional-commit / skillsys type (feat -> Creation, fix -> Update,
deprecate/remove -> Deprecation, ...). If a commit body carries a `Lesson:` or
`learned:` trailer, it is appended inline (the durable "why").

Re-run anytime; never hand-edit. Stdlib only (shells out to `git`).
"""
import re
import argparse
import subprocess
import collections

TYPE_WORD = {
    "feat": "Creation", "add": "Creation",
    "fix": "Update", "refactor": "Update", "docs": "Update",
    "chore": "Update", "skillsys": "Update", "perf": "Update",
    "deprecate": "Deprecation", "remove": "Deprecation", "revert": "Deprecation",
}
US, RS = "\x1f", "\x1e"  # unit / record separators


def git_log(path, max_count):
    fmt = US.join(["%ad", "%s", "%b"]) + RS
    cmd = ["git", "log", "--date=short", f"--pretty=format:{fmt}"]
    if max_count:
        cmd.append(f"-n{max_count}")
    if path:
        cmd += ["--", path]
    out = subprocess.run(cmd, capture_output=True, text=True, check=True).stdout
    for rec in out.split(RS):
        rec = rec.strip("\n")
        if not rec:
            continue
        parts = (rec.split(US) + ["", "", ""])[:3]
        yield parts[0].strip(), parts[1].strip(), parts[2].strip()


def classify(subject):
    m = re.match(r"^(\w+)(\([^)]*\))?!?:\s*(.*)$", subject)
    if m:
        return TYPE_WORD.get(m.group(1).lower(), "Update"), m.group(3)
    return "Update", subject


def lesson_of(body):
    lines = body.splitlines()
    for i, ln in enumerate(lines):
        m = re.match(r"^(Lesson|learned):\s*(.+)$", ln.strip(), re.I)
        if m:
            val = [m.group(2).strip()]
            for cont in lines[i + 1:]:  # fold continuation lines (until blank / next key)
                s = cont.strip()
                if not s or re.match(r"^[A-Za-z][\w-]*:\s", s):
                    break
                val.append(s)
            return " ".join(val)
    return None


def main():
    ap = argparse.ArgumentParser(description="Generate OKF log.md from git history (section 7).")
    ap.add_argument("--path", default=None, help="scope to a path within the repo")
    ap.add_argument("-n", "--max", type=int, default=0, help="max commits (0 = all)")
    ap.add_argument("--title", default="Directory Update Log", help="H1 title")
    ap.add_argument("-o", "--out", default="log.md", help="output path")
    args = ap.parse_args()

    by_date = collections.OrderedDict()  # git log is newest-first; preserve it
    for date, subject, body in git_log(args.path, args.max):
        word, text = classify(subject)
        lesson = lesson_of(body)
        entry = f"* **{word}**: {text}"
        if lesson:
            entry += f" - _lesson:_ {lesson}"
        by_date.setdefault(date, []).append(entry)

    lines = [f"# {args.title}", ""]
    for date, entries in by_date.items():
        lines.append(f"## {date}")
        lines += entries
        lines.append("")

    open(args.out, "w", encoding="utf-8").write("\n".join(lines).rstrip() + "\n")
    total = sum(len(v) for v in by_date.values())
    print(f"wrote {args.out} ({total} entr(y/ies) across {len(by_date)} day(s))")


if __name__ == "__main__":
    main()
